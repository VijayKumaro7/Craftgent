# ─────────────────────────────────────────────────────────────────────────
# CraftAgent Environment Configuration
# ─────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────
# API Keys & Secrets (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────

# Anthropic Claude API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Secret key for JWT tokens (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-min-32-chars-generate-with-secrets

# ─────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://craftgent:craftgent_dev_password@localhost:5432/craftgent
POSTGRES_USER=craftgent
POSTGRES_PASSWORD=craftgent_dev_password
POSTGRES_DB=craftgent

# ─────────────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis_dev_password

# ─────────────────────────────────────────────────────────────────────────
# ChromaDB Configuration
# ─────────────────────────────────────────────────────────────────────────

CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─────────────────────────────────────────────────────────────────────────
# Frontend Configuration
# ─────────────────────────────────────────────────────────────────────────

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ─────────────────────────────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────────────────────────────

# Development: local ports
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Production: your domain(s)
# CORS_ORIGINS=https://craftgent.example.com,https://api.example.com

# ─────────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────────

# Environment: development, staging, production
APP_ENV=development

# Log level: debug, info, warning, error
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────
# Optional: Third-party Services
# ─────────────────────────────────────────────────────────────────────────

# Tavily API key for enhanced web search (optional)
TAVILY_API_KEY=

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://...@sentry.io/...

# ─────────────────────────────────────────────────────────────────────────
# Optional: AWS/Storage Configuration (Phase 4+)
# ─────────────────────────────────────────────────────────────────────────

# AWS S3 for file uploads (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────
# Production Deployment Secrets
# (Use these only in production .env.prod file)
# ─────────────────────────────────────────────────────────────────────────

# Email configuration (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# SSL/TLS (for production)
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Rate limiting
RATE_LIMIT_PER_MIN=20
