# ══════════════════════════════════════════════════════════════════════════════
# CRAFTGENT ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control!
# 
# To generate a strong SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# 

# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
# Options: development, staging, production
# Set to 'production' for deployment with all security hardening

SECRET_KEY=your-secret-key-here-min-32-chars-required
# CRITICAL: Generate a strong 32+ character secret for JWT signing
# Development default below is for local testing only

DEBUG=false
# Keep false in production to prevent sensitive error exposure

# ─── Anthropic API ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# Get from: https://console.anthropic.com/account/keys
# Required for agent responses

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://craftgent:craftgent@localhost:5432/craftgent
# Format: postgresql+asyncpg://user:password@host:port/database
# For production, use a managed database (RDS, Supabase, etc.)
# Connection pooling recommended: ?min_size=5&max_size=20

POSTGRES_USER=craftgent
POSTGRES_PASSWORD=craftgent
POSTGRES_DB=craftgent
# Used by docker-compose for local PostgreSQL setup

# ─── Redis (Task Queue) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Format: redis://[:password@]host:port/database
# For production with auth: redis://:password@host:6379/0

REDIS_PASSWORD=craftgent_redis
# Optional password for Redis security

# ─── ChromaDB (Vector Store / Memory) ────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
# Used for RAG memory and semantic search

CHROMA_COLLECTION=craftgent_memory
# Collection name for storing agent memories

# ─── External Tools ─────────────────────────────────────────────────────
TAVILY_API_KEY=
# Optional: For web search capability
# Get from: https://tavily.com
# Leave empty to disable web search

CODE_EXEC_TIMEOUT=10
# Maximum seconds for code execution (Agent tool)

# ─── CORS & Security ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
# Comma-separated list of allowed origins
# Development: http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com

RATE_LIMIT_PER_MINUTE=20
# API rate limiting per IP per minute
# Adjust based on expected load

# ─── Frontend (Vite) ────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
# Backend API URL for frontend requests
# Production: https://api.yourdomain.com

VITE_WS_URL=ws://localhost:8000
# WebSocket URL for real-time chat
# Production: wss://api.yourdomain.com (note: wss for HTTPS)

# ─── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─── Email (Future) ─────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@craftgent.com

# ─── Sentry (Error Tracking, Optional) ──────────────────────────────────
# SENTRY_DSN=https://xxxxx@sentry.io/123456
# Leave empty to disable Sentry error reporting

# ─── Docker Deployment ──────────────────────────────────────────────────
# These are set in docker-compose files but documented here:
# DATABASE_URL - Override for production managed database
# REDIS_URL - Override for production Redis cluster
# APP_ENV - Set to 'production' for deployment
