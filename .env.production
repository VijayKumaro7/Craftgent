# ═══════════════════════════════════════════════════════════════════════════
# CRAFTGENT PRODUCTION ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════
#
# SECURITY: Never commit this file to git!
# Store secrets in AWS Secrets Manager, HashiCorp Vault, or similar
#
# To generate SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# To generate REDIS_PASSWORD:
#   openssl rand -base64 32
# ═══════════════════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
SECRET_KEY=<GENERATE-VIA-SECRETS-MANAGER>

# ─── Anthropic API ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── Database (Managed PostgreSQL) ──────────────────────────────────────────
#
# AWS RDS Example:
# DATABASE_URL=postgresql+asyncpg://user:pass@instance.region.rds.amazonaws.com:5432/craftgent?sslmode=require
#
# Supabase Example:
# DATABASE_URL=postgresql+asyncpg://postgres:pass@db.xxxxx.supabase.co:5432/postgres?sslmode=require
#
# Google Cloud SQL Example:
# DATABASE_URL=postgresql+asyncpg://postgres:pass@cloudsql/project:region:instance/craftgent?sslmode=require
#
DATABASE_URL=postgresql+asyncpg://user:password@hostname:5432/craftgent?sslmode=require

# ─── Redis (for task queue) ─────────────────────────────────────────────────
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=<GENERATE-VIA-OPENSSL>

# ─── ChromaDB (vector store) ────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION=craftgent_memory

# ─── Security & CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
RATE_LIMIT_PER_MINUTE=20

# ─── Frontend URLs ──────────────────────────────────────────────────────────
VITE_API_URL=https://yourdomain.com/api
VITE_WS_URL=wss://yourdomain.com

# ─── Monitoring & Logging ──────────────────────────────────────────────────
SENTRY_DSN=https://key@xxx.ingest.sentry.io/123456
LOG_LEVEL=INFO

# ─── External APIs ──────────────────────────────────────────────────────────
TAVILY_API_KEY=<optional-for-web-search>
CODE_EXEC_TIMEOUT=10

# ─── Email (Optional, for password reset) ──────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=<sendgrid-api-key>
SMTP_FROM=noreply@yourdomain.com

# ─── PostgreSQL Docker Credentials (for migrations if needed) ────────────────
POSTGRES_USER=craftgent_admin
POSTGRES_PASSWORD=<generate-random>
POSTGRES_DB=craftgent
